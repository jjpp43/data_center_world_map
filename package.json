{
  "name": "data-center-map",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/check-security.mjs && tsx --env-file-if-exists=.env.local scripts/build-geojson.ts",
    "build": "next build",
    "start": "next start",
    "ingest": "tsx --env-file=.env.local scripts/ingest.ts",
    "audit:quality": "tsx --env-file=.env.local scripts/audit-quality.ts",
    "canonicalize:orphans": "tsx --env-file=.env.local scripts/canonicalize-orphans.ts",
    "ingest:ironmountain": "tsx --env-file=.env.local scripts/ingest-ironmountain.ts",
    "ingest:google": "tsx --env-file=.env.local scripts/ingest-google.ts",
    "ingest:meta": "tsx --env-file=.env.local scripts/ingest-meta.ts",
    "check:security": "node --env-file=.env.local scripts/check-security.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "mapbox-gl": "^3.8.0",
    "next": "16.2.6",
    "posthog-js": "^1.386.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
